# Bloqueo de ejecución de scripts
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
php_flag engine off
Options -ExecCGI

<FilesMatch "\.(php|phtml|php\d+|phar|cgi|pl|py|sh)$">
  Require all denied
</FilesMatch>

# Permitir solo archivos estáticos
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|pdf|txt|zip|rar|dxf|dwg)$">
  Require all granted
</FilesMatch>

<FilesMatch ".*">
  Require all denied
</FilesMatch>

# (Opcional) Si quieres mantener CORS por si alguien accede directamente, puedes añadir:
# <IfModule mod_headers.c>
#   Header set Access-Control-Allow-Origin "https://www.dbsdesigner.com"
# </IfModule>
# Pero no es necesario porque PHP ya lo envía.
