# ===========================================
# SECURITY RULES FOR /uploads/
# ===========================================

# 🚫 1. Disable PHP execution (critical)
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
php_flag engine off
Options -ExecCGI

# Extra protection against script execution
<FilesMatch "\.(php|phtml|php\d+|phar|cgi|pl|py|sh)$">
  Require all denied
</FilesMatch>

# ===========================================
# 2. Allow ONLY static files publicly
# ===========================================
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|pdf|txt|zip|rar|dxf|dwg)$">
  Require all granted
</FilesMatch>

# Deny everything else explicitly
<FilesMatch ".*">
  Require all denied
</FilesMatch>

# ===========================================
# 3. CORS — allow Cloudflare/dbsdesigner.com to access the files
# ===========================================
<IfModule mod_headers.c>
  Header set Access-Control-Allow-Origin "https://dbsdesigner.com"
  Header set Access-Control-Allow-Methods "GET, OPTIONS"
  Header set Access-Control-Allow-Headers "Content-Type"
</IfModule>

# ===========================================
# 4. Cache static files (improves performance)
# ===========================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg  "access plus 30 days"
  ExpiresByType image/png   "access plus 30 days"
  ExpiresByType image/webp  "access plus 30 days"
  ExpiresByType application/pdf "access plus 30 days"
  ExpiresDefault "access plus 14 days"
</IfModule>
