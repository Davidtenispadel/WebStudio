# No ejecutar código: solo estáticos
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8
php_flag engine off
Options -ExecCGI

<FilesMatch "\.(php|phtml|php\d+|phar|cgi|pl|py|sh)$">
  Require all denied
</FilesMatch>

# Permitir solo archivos estáticos
<FilesMatch "\.(jpg|jpeg|png|gif|pdf|webp|txt|zip|rar|dxf|dwg)$">
  Require all granted
</FilesMatch>

<FilesMatch ".*">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header set Access-Control-Allow-Origin "https://dbsdesigner.com"
</IfModule>
